{
  // Use the project's uv-managed virtualenv as the interpreter.
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  // Test discovery: pytest, not unittest.
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,

  // Ruff as formatter + linter; tidy imports and autofix on save.
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports.ruff": "explicit",
      "source.fixAll.ruff": "explicit"
    }
  },

  // Hide generated/cache artifacts from the file tree (all git-ignored).
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/.ruff_cache": true,
    "**/*.egg-info": true
  }
}
